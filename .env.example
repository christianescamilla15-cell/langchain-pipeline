# LangChain Pipeline Environment Variables

# Anthropic API (optional - enables real LLM calls)
ANTHROPIC_API_KEY=

# AWS Bedrock (optional - alternative to Anthropic)
AWS_DEFAULT_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Server
HOST=0.0.0.0
PORT=8000

# Mode: "demo" uses mock LLM, "live" uses real API
MODE=demo
